# ── Dataset ─────────────────────────────────────────────────────────────────
# Options: nq | scifact | qasper | quality
DATASET=nq

# Options: train | dev | test  (not all datasets have all splits)
DATASET_SPLIT=test

# Number of samples to evaluate. 0 = full dataset
DATASET_SAMPLE=200

# ── Chunking ─────────────────────────────────────────────────────────────────
# Options: fixed | semantic | section_then_semantic
CHUNK_STRATEGY=semantic

# Used when CHUNK_STRATEGY=fixed
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Used when CHUNK_STRATEGY=semantic or section_then_semantic
# Cosine similarity drop threshold to trigger a new chunk
SEMANTIC_THRESHOLD=0.35
CHUNK_MIN_CHARS=200
CHUNK_MAX_CHARS=1000

# ── Embedding Model ───────────────────────────────────────────────────────────
# Recommended options:
#   sentence-transformers/all-MiniLM-L6-v2   (fast, lightweight, English)
#   BAAI/bge-large-en-v1.5                   (strong English retrieval)
#   intfloat/e5-large-v2                     (strong English retrieval)
#   BAAI/bge-m3                              (multilingual, dense+sparse)
EMBED_MODEL=BAAI/bge-large-en-v1.5

EMBED_BATCH_SIZE=64

# Options: cpu | cuda | mps
# mps = Apple Silicon GPU
EMBED_DEVICE=cpu

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Options: dense | sparse | hybrid
RETRIEVAL_MODE=hybrid

# Total candidates to retrieve before reranking
RETRIEVE_K=20

# RRF formula constant (higher = less sensitive to rank differences)
RRF_K=60

# Weights must sum to 1.0
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4

# ── Reranker ──────────────────────────────────────────────────────────────────
# Options: none | cross-encoder
RERANKER=cross-encoder

# Recommended options:
#   cross-encoder/ms-marco-MiniLM-L-6-v2   (fast, lightweight)
#   BAAI/bge-reranker-large                (stronger, slower)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# How many chunks to keep after reranking (passed to LLM context)
RERANK_TOP_K=5

# ── Evaluation Metrics ────────────────────────────────────────────────────────
# Comma-separated list of metrics to compute
# Retrieval: mrr, ndcg, hit, recall
# Answer quality: f1, bertscore  (only for datasets with reference answers)
EVAL_METRICS=mrr,ndcg,hit,recall,f1,bertscore

# @K values for retrieval metrics
EVAL_K_VALUES=1,3,5,10

# ── Run Management ────────────────────────────────────────────────────────────
RUN_NAME=exp_001
RESULTS_DIR=./results
CACHE_DIR=./cache
